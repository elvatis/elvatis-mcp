# elvatis-mcp — environment variables
# Copy this file to .env and fill in your values.
# .env is gitignored and must never be committed.

# -------------------------
# Home Assistant (required)
# -------------------------
HA_URL=http://YOUR_HA_IP:8123
HA_TOKEN=YOUR_LONG_LIVED_HA_TOKEN

# -------------------------
# SSH access to OpenClaw server (required)
# Used by: cron tools, memory tools, openclaw_run
# -------------------------
SSH_HOST=YOUR_OPENCLAW_SERVER_IP
SSH_PORT=22
SSH_USER=YOUR_SSH_USERNAME
# Use a full absolute path — ~ expansion is unreliable across clients (Claude Desktop vs Claude Code)
# Windows:  SSH_KEY_PATH=C:/Users/your-username/.ssh/your_key
# macOS/Linux: SSH_KEY_PATH=/home/your-username/.ssh/your_key
SSH_KEY_PATH=C:/Users/your-username/.ssh/YOUR_KEY_NAME

# -------------------------
# OpenClaw Gateway (WebSocket tunnel forwarded locally)
# Start tunnel: ssh -i ~/.ssh/YOUR_KEY_NAME -L 18789:127.0.0.1:18789 -N USER@HOST
# -------------------------
OPENCLAW_GATEWAY_URL=http://localhost:18789

# -------------------------
# OpenClaw sub-agent (optional)
# Name of the agent to use for openclaw_run. Omit to use OpenClaw's default agent.
# See your agents: ssh <server> "openclaw agents list"
# -------------------------
# OPENCLAW_DEFAULT_AGENT=ops

# -------------------------
# Gemini CLI (optional)
# Requires: npm install -g @google/gemini-cli && gemini auth login
# Default model is gemini-2.5-flash if omitted.
# -------------------------
# GEMINI_MODEL=gemini-2.5-pro

# -------------------------
# Codex CLI (optional)
# Requires: npm install -g @openai/codex && codex login
# Default model is whatever codex is configured to use if omitted.
# -------------------------
# CODEX_MODEL=o3

# -------------------------
# MCP transport (optional, default: stdio)
# -------------------------
# MCP_TRANSPORT=stdio
# MCP_HTTP_PORT=3333

# -------------------------
# Remote Linux server (optional)
# Used by: remote_shell, remote_docker (T-011), remote_service (T-012)
# REMOTE_HOST defaults to SSH_HOST if not set.
# REMOTE_KEY_PATH defaults to SSH_KEY_PATH if not set.
# -------------------------
# REMOTE_HOST=YOUR_LINUX_SERVER_IP
# REMOTE_PORT=22
# REMOTE_USER=root
# Windows:  REMOTE_KEY_PATH=C:/Users/your-username/.ssh/your_key
# macOS/Linux: REMOTE_KEY_PATH=/home/your-username/.ssh/your_key
# REMOTE_KEY_PATH=C:/Users/your-username/.ssh/YOUR_KEY_NAME

# -------------------------
# SSH debugging (optional)
# Set to 1 to add -vvv verbose flag to all SSH calls.
# Useful when SSH fails with exit 255 and no output.
# -------------------------
# SSH_DEBUG=1

# -------------------------
# Rate limiting (optional)
# Directory for persistent usage data. Default: ~/.elvatis-mcp
# -------------------------
# ELVATIS_DATA_DIR=~/.elvatis-mcp

# Per-agent rate limit overrides (JSON string).
# Default limits: claude_run 5/min 30/hr 200/day, codex_run 5/min 30/hr 200/day, gemini_run 10/min 60/hr 500/day
# Example: RATE_LIMITS={"claude_run":{"perMinute":3,"perDay":100}}
