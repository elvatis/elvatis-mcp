{
  "name": "@elvatis_com/elvatis-mcp",
  "version": "1.2.2",
  "description": "MCP server for OpenClaw — expose smart home, memory, cron, and more to Claude Desktop, Cursor, Windsurf, and any MCP client",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "elvatis-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "npm run build && npx tsx --test tests/unit.test.ts",
    "test:integration": "npx tsx tests/integration.test.ts",
    "typecheck": "tsc --noEmit",
    "prepare": "npm run build",
    "prepublishOnly": "npm run typecheck && npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "openclaw",
    "elvatis",
    "home-assistant",
    "ai",
    "claude"
  ],
  "author": "Elvatis <emre.kohler@elvatis.com>",
  "license": "Apache-2.0",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.10.2",
    "dotenv": "^16.4.7",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    ".env.example",
    ".mcp.json.example"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/elvatis/elvatis-mcp.git"
  },
  "publishConfig": {
    "access": "public"
  }
}
